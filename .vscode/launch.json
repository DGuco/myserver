    "version": "0.2.0",
    "configurations": [
        {
            "name": "AttachProcess",
            "type": "cppvsdbg",
            "request": "attach",
            "processId": "${command:pickProcess}"
        },
        {
            "name": "ProxyServer",
            "type": "cppvsdbg",
            "request": "launch",
            "program": " ${workspaceFolder}/run/proxyserver.exe",
            "args": [],
            "stopAtEntry": false,
            //"cwd": "${fileDirname}",
            "cwd": "${workspaceFolder}/run", //固定工作目录，否则调试程序运行时的工作目录不正确，从而影响文件读取、日志生成等。
            "environment": [],
            "console": "externalTerminal",
        },
        {
            "name": "GameServer",
            "type": "cppvsdbg",
            "request": "launch",
            "program": " ${workspaceFolder}/run/gameserver.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/run",
            "environment": [],
            "console": "externalTerminal"
        },
        {
            "name": "DbServer",
            "type": "cppvsdbg",
            "request": "launch",
            "program": " ${workspaceFolder}/run/dbserver.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/run",
            "environment": [],
            "console": "externalTerminal"
        }
  
    ]
}